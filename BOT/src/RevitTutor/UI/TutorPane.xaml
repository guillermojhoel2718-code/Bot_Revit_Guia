<UserControl x:Class="RevitTutor.TutorPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA" MinWidth="300" MinHeight="400"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- Colores -->
        <SolidColorBrush x:Key="BgPrimary" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="BgWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentColor" Color="#06B6D4"/>
        <SolidColorBrush x:Key="TextMain" Color="#111827"/>
        <SolidColorBrush x:Key="TextSub" Color="#4B5563"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#E5E7EB"/>

        <!-- Estilo del botón Enviar -->
        <Style x:Key="AskButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Titulo -->
            <RowDefinition Height="*"/>    <!-- Respuesta -->
            <RowDefinition Height="Auto"/> <!-- Sugerencias -->
            <RowDefinition Height="Auto"/> <!-- Input -->
            <RowDefinition Height="Auto"/> <!-- Boton -->
            <RowDefinition Height="Auto"/> <!-- API Key -->
        </Grid.RowDefinitions>

        <!-- Encabezado (título) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Tutor IA para Revit"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="Haz una pregunta sobre el modelo y te llevaré a la vista o elementos relevantes. Prueba también comandos como: 'selecciona los muros', 've a la vista 3D' o 'ayúdame con este nivel'."
                       FontSize="12"
                       Foreground="{StaticResource TextSub}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Zona central: texto de respuesta principal -->
        <Border Grid.Row="1" CornerRadius="12"
                Background="{StaticResource BgWhite}"
                BorderBrush="{StaticResource AccentColor}"
                BorderThickness="2"
                Margin="0,0,0,16" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="txtRespuesta"
                           Text="Haz una pregunta sobre el modelo (por ejemplo: 'selecciona los muros y suelos') y te guiaré."
                           Foreground="{StaticResource TextMain}"
                           FontSize="14"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <!-- Comandos Sugeridos -->
        <Expander Grid.Row="2" Header="Ver comandos sugeridos" 
                  Foreground="{StaticResource TextSub}" FontSize="12"
                  Margin="0,0,0,12" Background="Transparent">
            <Border Background="{StaticResource BgWhite}" CornerRadius="8" 
                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" 
                    Padding="4" MaxHeight="150">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Navegación" FontWeight="Bold" Margin="4,4,4,2" FontSize="11"/>
                        <ListBox x:Name="lstNavCommands" BorderThickness="0" Background="Transparent" SelectionChanged="OnCommandSelected">
                            <ListBoxItem Content="ve a la planta Nivel 1" Padding="4,2"/>
                            <ListBoxItem Content="ve al alzado Norte" Padding="4,2"/>
                            <ListBoxItem Content="ve a la vista 3D principal" Padding="4,2"/>
                        </ListBox>

                        <TextBlock Text="Visibilidad" FontWeight="Bold" Margin="4,8,4,2" FontSize="11"/>
                        <ListBox x:Name="lstVisCommands" BorderThickness="0" Background="Transparent" SelectionChanged="OnCommandSelected">
                            <ListBoxItem Content="muestra los muros" Padding="4,2"/>
                            <ListBoxItem Content="oculta las anotaciones" Padding="4,2"/>
                            <ListBoxItem Content="muestra solo las vigas" Padding="4,2"/>
                            <ListBoxItem Content="limpia los colores" Padding="4,2"/>
                        </ListBox>

                        <TextBlock Text="Educativo y Calidad" FontWeight="Bold" Margin="4,8,4,2" FontSize="11"/>
                        <ListBox x:Name="lstEduCommands" BorderThickness="0" Background="Transparent" SelectionChanged="OnCommandSelected">
                            <ListBoxItem Content="enséñame a modelar una losa" Padding="4,2"/>
                            <ListBoxItem Content="explícame cómo dibujar una trabe" Padding="4,2"/>
                            <ListBoxItem Content="revisión de calidad" Padding="4,2"/>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Expander>

        <!-- Campo de pregunta -->
        <Border Grid.Row="3" CornerRadius="8"
                Background="{StaticResource BgWhite}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                Margin="0,0,0,12">
            <TextBox x:Name="txtQuestion"
                     Text="selecciona los muros"
                     Background="Transparent"
                     Foreground="{StaticResource TextMain}"
                     FontSize="14"
                     BorderThickness="0"
                     Padding="12,10"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Center"
                     GotFocus="txtQuestion_GotFocus"/>
        </Border>

        <!-- Botón Preguntar al tutor y Sprite de estado -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnSend"
                    Grid.Column="0"
                    Content="Preguntar al tutor"
                    Style="{StaticResource AskButtonStyle}"
                    Click="btnSend_Click"
                    HorizontalAlignment="Stretch"/>

            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0,0,0">
                <Grid x:Name="BotContainer" HorizontalAlignment="Center">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="BotTransform" />
                    </Grid.RenderTransform>
                    <Image x:Name="imgBot" Width="48" Height="48" 
                           Stretch="Uniform"
                           Source="pack://application:,,,/RevitTutor;component/Resources/sprites/estatico.png" />
                </Grid>
                <TextBlock x:Name="txtBotStatus" Text="En espera" 
                           Foreground="{StaticResource TextSub}" FontSize="11" 
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock x:Name="txtBotSummary" Text="" 
                           Foreground="{StaticResource PrimaryColor}" FontSize="10" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,2,0,0"
                           TextWrapping="Wrap" MaxWidth="100" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Sección BYOK -->
        <StackPanel Grid.Row="5" Margin="0,16,0,0">
            <TextBlock Text="Para usar IA avanzada, consigue tu API key de Gemini:" TextWrapping="Wrap" Margin="0,0,0,4" Foreground="{StaticResource TextSub}" FontSize="12"/>
            <TextBlock Margin="0,0,0,8" FontSize="11">
                <Hyperlink NavigateUri="https://aistudio.google.com/apikey" RequestNavigate="OnApiKeyLinkClick">
                    https://aistudio.google.com/apikey
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="Pega aquí tu API key de Gemini:" Margin="0,0,0,4" Foreground="{StaticResource TextSub}" FontSize="12"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="txtApiKey"
                         Grid.Column="0"
                         Background="{StaticResource BgWhite}"
                         Foreground="{StaticResource TextMain}"
                         BorderBrush="{StaticResource BorderSoft}"
                         BorderThickness="1"
                         Padding="8"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        x:Name="btnSaveApiKey"
                        Content="Guardar API key"
                        Background="{StaticResource BorderSoft}"
                        Foreground="{StaticResource TextMain}"
                        BorderThickness="0"
                        Padding="12,8"
                        Cursor="Hand"
                        Click="OnSaveApiKeyClick"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
