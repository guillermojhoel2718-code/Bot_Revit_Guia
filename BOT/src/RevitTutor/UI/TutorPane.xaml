<UserControl x:Class="RevitTutor.TutorPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA" MinWidth="300" MinHeight="400"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- Colores -->
        <SolidColorBrush x:Key="BgPrimary" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="BgWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentColor" Color="#06B6D4"/>
        <SolidColorBrush x:Key="TextMain" Color="#111827"/>
        <SolidColorBrush x:Key="TextSub" Color="#4B5563"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#E5E7EB"/>

        <!-- Estilo del botón Enviar -->
        <Style x:Key="AskButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado (título) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Tutor IA para Revit"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="Haz una pregunta sobre el modelo y te llevaré a la vista o elementos relevantes."
                       FontSize="12"
                       Foreground="{StaticResource TextSub}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Zona central: sprite + texto de respuesta -->
        <Border Grid.Row="1" CornerRadius="12"
                Background="{StaticResource BgWhite}"
                BorderBrush="{StaticResource AccentColor}"
                BorderThickness="2"
                Margin="0,0,0,16" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Sprite en contenedor animable -->
                <Grid x:Name="BotContainer" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,12,0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="BotTransform" />
                    </Grid.RenderTransform>
                    <Image x:Name="imgBot" Width="64" Height="64" 
                           Stretch="Uniform" HorizontalAlignment="Center"
                           Source="pack://application:,,,/RevitTutor;component/Resources/sprites/estatico.png" />
                </Grid>
                
                <!-- Texto de respuesta -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtRespuesta"
                               Text="Haz una pregunta sobre el modelo (por ejemplo: 'muéstrame los muros') y te guiaré."
                               Foreground="{StaticResource TextMain}"
                               FontSize="14"
                               TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Campo de pregunta -->
        <Border Grid.Row="2" CornerRadius="8"
                Background="{StaticResource BgWhite}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                Margin="0,0,0,12">
            <TextBox x:Name="txtQuestion"
                     Text="muéstrame los muros"
                     Background="Transparent"
                     Foreground="{StaticResource TextMain}"
                     FontSize="14"
                     BorderThickness="0"
                     Padding="12,10"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Center"
                     GotFocus="txtQuestion_GotFocus"/>
        </Border>

        <!-- Botón Preguntar al tutor -->
        <Button Grid.Row="3"
                x:Name="btnSend"
                Content="Preguntar al tutor"
                Style="{StaticResource AskButtonStyle}"
                Click="btnSend_Click"
                HorizontalAlignment="Stretch"/>

        <!-- Sección BYOK -->
        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock Text="Para usar IA avanzada, consigue tu API key de Gemini:" TextWrapping="Wrap" Margin="0,0,0,4" Foreground="{StaticResource TextSub}" FontSize="12"/>
            <TextBlock Margin="0,0,0,8" FontSize="11">
                <Hyperlink NavigateUri="https://aistudio.google.com/apikey" RequestNavigate="OnApiKeyLinkClick">
                    https://aistudio.google.com/apikey
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="Pega aquí tu API key de Gemini:" Margin="0,0,0,4" Foreground="{StaticResource TextSub}" FontSize="12"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtApiKey"
                         Grid.Column="0"
                         Background="{StaticResource BgWhite}"
                         Foreground="{StaticResource TextMain}"
                         BorderBrush="{StaticResource BorderSoft}"
                         BorderThickness="1"
                         Padding="8"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        x:Name="btnSaveApiKey"
                        Content="Guardar API key"
                        Background="{StaticResource BorderSoft}"
                        Foreground="{StaticResource TextMain}"
                        BorderThickness="0"
                        Padding="12,8"
                        Cursor="Hand"
                        Click="OnSaveApiKeyClick"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
