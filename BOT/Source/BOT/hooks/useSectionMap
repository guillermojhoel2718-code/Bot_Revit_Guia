/**
 * useSectionMap — Registra y gestiona las secciones navegables del portafolio.
 *
 * Cada sección del sitio se registra con un `id` lógico y un `ref` al DOM.
 * El hook devuelve funciones para buscar secciones por ID.
 *
 * Uso:
 *   const { registerSection, getSectionById, sections } = useSectionMap();
 *   registerSection('revit-muros', 'Muros en Revit', miRef);
 */

import { useCallback, useRef } from 'react';

export interface Section {
  id: string;
  label: string;
  ref: React.RefObject<HTMLElement>;
}

export function useSectionMap() {
  const sectionsRef = useRef<Map<string, Section>>(new Map());

  /**
   * Registra una sección navegable.
   */
  const registerSection = useCallback(
    (id: string, label: string, ref: React.RefObject<HTMLElement>) => {
      sectionsRef.current.set(id, { id, label, ref });
    },
    []
  );

  /**
   * Busca una sección por su ID lógico.
   */
  const getSectionById = useCallback((id: string): Section | undefined => {
    return sectionsRef.current.get(id);
  }, []);

  /**
   * Devuelve todos los IDs de secciones registradas.
   */
  const getAllSectionIds = useCallback((): string[] => {
    return Array.from(sectionsRef.current.keys());
  }, []);

  return {
    registerSection,
    getSectionById,
    getAllSectionIds,
    sections: sectionsRef,
  };
}
