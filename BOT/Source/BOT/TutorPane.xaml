<UserControl x:Class="RevitTutor.TutorPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1e1e2e" MinWidth="300" MinHeight="400">

    <UserControl.Resources>
        <!-- Colores del tema oscuro -->
        <SolidColorBrush x:Key="BgPrimary" Color="#1e1e2e"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#282840"/>
        <SolidColorBrush x:Key="BgInput" Color="#313150"/>
        <SolidColorBrush x:Key="AccentColor" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentHover" Color="#818cf8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e2e8f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94a3b8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3b3b5c"/>

        <!-- Estilo del botón Enviar -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🤖 Tutor IA"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Pregúntame sobre el modelo — solo lectura"
                       FontSize="11"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Campo de pregunta -->
        <Border Grid.Row="1" CornerRadius="8"
                Background="{StaticResource BgInput}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                Margin="0,0,0,8">
            <TextBox x:Name="txtQuestion"
                     Text=""
                     Background="Transparent"
                     Foreground="{StaticResource TextPrimary}"
                     FontSize="13"
                     BorderThickness="0"
                     Padding="12,10"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Center"
                     ToolTip="Escribe tu pregunta aquí..."/>
        </Border>

        <!-- Botón Enviar -->
        <Button Grid.Row="2"
                x:Name="btnSend"
                Content="📤 Enviar pregunta"
                Style="{StaticResource SendButtonStyle}"
                Click="btnSend_Click"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,12"/>

        <!-- Log / JSON de contexto -->
        <Border Grid.Row="3" CornerRadius="8"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                Margin="0,0,0,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="txtLog"
                         Text="El contexto del modelo aparecerá aquí..."
                         Background="Transparent"
                         Foreground="{StaticResource TextSecondary}"
                         FontSize="11"
                         FontFamily="Consolas"
                         BorderThickness="0"
                         Padding="12,10"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="4"
                   Text="RevitTutorIA v1.0 — Solo lectura"
                   FontSize="10"
                   Foreground="{StaticResource TextSecondary}"
                   HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
